{
  "mcpServers": {
    "cos": {
      "type": "stdio",
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/server.py"],
      "env": {
        "COS_SECRET_ID": "${COS_SECRET_ID}",
        "COS_SECRET_KEY": "${COS_SECRET_KEY}",
        "COS_BUCKET": "${COS_BUCKET}",
        "COS_REGION": "${COS_REGION:-ap-shanghai}",
        "COS_PREFIX": "${COS_PREFIX:-tmp}"
      }
    }
  }
}
