{
  "name": "email-mcp",
  "description": "通用 SMTP/IMAP 邮件 MCP server：发邮件（支持附件）、列邮件、读邮件正文/附件、搜索、标记已读",
  "version": "1.0.1",
  "author": {
    "name": "Jeffrey"
  },
  "homepage": "https://github.com/wb4646684/claude-plugins/tree/main/plugins/email-mcp",
  "repository": "https://github.com/wb4646684/claude-plugins",
  "license": "MIT",
  "keywords": ["email", "smtp", "imap", "mcp", "qqmail", "163mail", "gmail"],
  "userConfig": {
    "smtp_host": {
      "description": "SMTP 服务器（QQ: smtp.qq.com / 163: smtp.163.com / Gmail: smtp.gmail.com）",
      "sensitive": false
    },
    "smtp_port": {
      "description": "SMTP 端口（SSL 用 465，STARTTLS 用 587，默认 465）",
      "sensitive": false
    },
    "smtp_ssl": {
      "description": "SMTP 是否启用 SSL（true/false，默认 true）",
      "sensitive": false
    },
    "smtp_user": {
      "description": "发件邮箱地址",
      "sensitive": false
    },
    "smtp_pass": {
      "description": "SMTP 授权码（≠登录密码。QQ邮箱：设置→账户→生成授权码；Gmail：应用专用密码）",
      "sensitive": true
    },
    "display_name": {
      "description": "发件人显示名称（如 张锋）",
      "sensitive": false
    },
    "imap_host": {
      "description": "IMAP 服务器（QQ: imap.qq.com / 163: imap.163.com / Gmail: imap.gmail.com）",
      "sensitive": false
    },
    "imap_port": {
      "description": "IMAP 端口（默认 993）",
      "sensitive": false
    },
    "imap_ssl": {
      "description": "IMAP 是否启用 SSL（true/false，默认 true）",
      "sensitive": false
    },
    "imap_user": {
      "description": "收件邮箱地址（通常与发件地址相同）",
      "sensitive": false
    },
    "imap_pass": {
      "description": "IMAP 授权码（通常与 SMTP 授权码相同）",
      "sensitive": true
    }
  },
  "mcpServers": {
    "email": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/index.js"],
      "env": {
        "SMTP_HOST": "${user_config.smtp_host}",
        "SMTP_PORT": "${user_config.smtp_port}",
        "SMTP_SSL": "${user_config.smtp_ssl}",
        "SMTP_USER": "${user_config.smtp_user}",
        "SMTP_PASS": "${user_config.smtp_pass}",
        "DISPLAY_NAME": "${user_config.display_name}",
        "IMAP_HOST": "${user_config.imap_host}",
        "IMAP_PORT": "${user_config.imap_port}",
        "IMAP_SSL": "${user_config.imap_ssl}",
        "IMAP_USER": "${user_config.imap_user}",
        "IMAP_PASS": "${user_config.imap_pass}"
      }
    }
  }
}
